            "new_string": "const NO_REFRESH_ENDPOINTS = [\"/auth/refresh\", \"/auth/login\", \"/auth/register\", \"/auth/me\"];",
            "old_string": "const NO_REFRESH_ENDPOINTS = [\"/auth/refresh\", \"/auth/login\", \"/auth/register\"];",
